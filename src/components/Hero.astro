---
---
<div class="hero-wrap" style="background: var(--paper);">
  <span class="blob blob-1"></span>
  <span class="blob blob-2"></span>
  <div class="hero-section">
    <div>
      <p class="hero-eyebrow"><span class="wave">👋</span> Workforce &middot; Training &middot; Technology &middot; Creative</p>
      <h1 class="hero-name">Greg<br /><span>Thweatt</span></h1>
      <p class="hero-bio">I help organizations develop people, tell their stories through data, and build tools that make work easier. Based in Southern Oregon &mdash; available locally and remotely.</p>
      <div class="hero-actions">
        <a href="#work" class="btn btn-primary">View My Work</a>
        <a href="#contact" class="btn btn-outline">Get in Touch</a>
      </div>
    </div>
    <div class="hero-art-cluster">
      <div class="art-ring art-ring--md">
        <div class="art-circle art-circle--md">
          <img src="/emigrant-lake.jpg" alt="Emigrant Lake painting by Greg Thweatt" />
        </div>
      </div>
      <div class="art-ring art-ring--lg">
        <div class="art-circle art-circle--lg">
          <img src="/chat-noir.jpg" alt="Chat Noir cat artwork by Greg Thweatt" />
        </div>
      </div>
      <div class="art-ring art-ring--sm">
        <div class="art-circle art-circle--sm">
          <img src="/ukrainian-farmer.jpg" alt="Ukrainian Farmer artwork by Greg Thweatt" />
        </div>
      </div>
    </div>
  </div>
</div>
